page {
  background: #f7f8fa;
  color: #323233;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.muted {
  color: #969799;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gap-12 {
  height: 24rpx;
}

.sticky-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #ebedf0;
}

.bottom-spacer {
  height: 160rpx;
}

