.restaurant-card .title {
  font-size: 34rpx;
  font-weight: 600;
}

.restaurant-card .sub {
  margin-top: 6rpx;
  color: #969799;
  font-size: 24rpx;
}

.dish-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  background: #fff;
  border-radius: 16rpx;
}

.dish-item + .dish-item {
  margin-top: 16rpx;
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
}

.dish-meta {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #969799;
  font-size: 24rpx;
}

.dish-price {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ff6799;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty {
  min-width: 44rpx;
  text-align: center;
  font-weight: 600;
}

.bottom-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.bottom-summary .left .money {
  font-weight: 800;
  color: #ff6799;
}

.bottom-summary .left .small {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #969799;
}

