.restaurant-card .title {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.restaurant-card .sub {
  margin-top: 6rpx;
  color: rgba(43, 43, 43, 0.55);
  font-size: 24rpx;
}

.dish-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  background: rgba(255, 252, 246, 0.96);
  border-radius: 18rpx;
  border: 1rpx solid rgba(94, 60, 24, 0.16);
}

.dish-item + .dish-item {
  margin-top: 16rpx;
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.dish-meta {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: rgba(43, 43, 43, 0.55);
  font-size: 24rpx;
}

.dish-price {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #8b1a1a;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty {
  min-width: 44rpx;
  text-align: center;
  font-weight: 600;
}

.bottom-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.bottom-summary .left .money {
  font-weight: 800;
  color: #8b1a1a;
}

.bottom-summary .left .small {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: rgba(43, 43, 43, 0.55);
}

