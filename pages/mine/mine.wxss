.profile .left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #f2f3f5;
  border: 1rpx solid rgba(94, 60, 24, 0.18);
}

.info .name {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.info .sub {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.actions {
  padding: 20rpx;
}